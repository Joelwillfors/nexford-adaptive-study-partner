{
  "name": "nexford-docs-tooling",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build:onepager-pdf": "node scripts/build-onepager-pdf.mjs",
    "build:command-center-pdf": "node scripts/build-md-pdf.mjs --in Docs/COMMAND_CENTER.md --out Docs/COMMAND_CENTER.pdf",
    "build:public-pdfs": "npm run build:onepager-pdf && npm run build:command-center-pdf",
    "build:demo-pdf": "node scripts/build-md-pdf.mjs --in Docs/.archive/DEMO_SCRIPT.md --out Docs/.archive/DEMO_SCRIPT.pdf",
    "build:interview-prep-pdf": "node scripts/build-md-pdf.mjs --in Docs/.archive/INTERVIEW_PREP.md --out Docs/.archive/INTERVIEW_PREP.pdf",
    "build:cue-card-pdf": "node scripts/build-md-pdf.mjs --in Docs/.archive/DEMO_CUE_CARD.md --out Docs/.archive/DEMO_CUE_CARD.pdf --format A5 --margin 0.4in",
    "build:extra-pdfs": "npm run build:demo-pdf && npm run build:interview-prep-pdf && npm run build:cue-card-pdf"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.4.2",
    "md-to-pdf": "^5.2.4"
  }
}
